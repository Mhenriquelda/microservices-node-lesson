generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Order {
  id        String   @id @default(cuid())
  userId    String   // Apenas armazena o ID do usuário, não há relação de FK real
  items     Json     // SQLite não tem tipo JSON nativo, Prisma o emula com String
  total     Float
  status    String
  createdAt DateTime @default(now())
}